    <!-- Dialogs -->
    <string name="dialog_clear_cache_title">¿Borrar caché?</string>
    <string name="dialog_clear_cache_message">Esto borrará todos los datos de escaneo temporales. El historial de tu dispositivo se conservará.</string>
    <string name="dialog_clear_history_title">¿Borrar historial de dispositivos?</string>
    <string name="dialog_clear_history_message">Esto eliminará toda la información guardada de los dispositivos, incluidos los nombres personalizados. Esta acción no se puede deshacer.</string>
    <string name="dialog_about_title">Acerca de Network Scanner</string>
    <string name="dialog_about_message" formatted="true">Network Scanner es una potente herramienta para descubrir y analizar dispositivos en tu red local. Desarrollada pensando en tu privacidad. Todo el escaneo se realiza localmente en tu dispositivo. ⚠️ Nota: La detección de dispositivos y el escaneo de puertos no son 100%% precisos. Los resultados pueden variar según las condiciones de la red y las configuraciones de los dispositivos. Versión %s | Licencia GPL-3.0</string>
    <string name="view_on_github">Ver en GitHub</string>
    <string name="github_url">https://github.com/usamaiqb/network-scanner</string>
    <string name="deep_scan_disclaimer">La detección de puertos y SO son estimaciones y pueden no ser totalmente precisas</string>
    <string name="dialog_privacy_title">Política de privacidad</string>
    <string name="dialog_privacy_message">Network Scanner respeta tu privacidad: • Sin recopilación de datos: todos los resultados del escaneo permanecen en tu dispositivo • Sin anuncios ni rastreo • No se requiere permiso de Internet para escanear. El permiso de ubicación solo se usa para acceder a la información de Wi-Fi como lo requiere Android, no para rastrear tu ubicación.</string>
    <string name="dialog_theme_restart_title">Tema cambiado</string>
    <string name="dialog_theme_restart_message">Los cambios de color dinámicos surtirán efecto por completo después de reiniciar la aplicación.</string>

